{
  "openapi": "3.1.0",
  "info": {
    "title": "CyberAgora — Dynamic Approval Workflow API",
    "version": "1.0.0",
    "description": "REST API for a dynamic approval-workflow system.\nAdmins build forms with arbitrary fields and configure per-form approval workflows.\nRequesters submit filled forms; approvers act on items routed to them.\n\n**Authentication**: Sanctum personal-access tokens. Send `Authorization: Bearer <token>` on every authed request.\n\n**Workflow types**:\n- `sequential` — ordered approver list; advances step-by-step.\n- `threshold` — pool of approvers; once N approvals are recorded the request is approved. Any single rejection rejects the request.\n"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000/api",
      "description": "Local dev (php artisan serve)"
    }
  ],
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Forms (public)"
    },
    {
      "name": "Requester"
    },
    {
      "name": "Approver"
    },
    {
      "name": "Admin"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Sanctum"
      }
    },
    "schemas": {
      "UserRole": {
        "type": "string",
        "enum": [
          "admin",
          "requester",
          "approver"
        ]
      },
      "FieldType": {
        "type": "string",
        "enum": [
          "text",
          "textarea",
          "number",
          "select",
          "date",
          "checkbox",
          "file"
        ]
      },
      "WorkflowType": {
        "type": "string",
        "enum": [
          "sequential",
          "threshold"
        ]
      },
      "RequestStatus": {
        "type": "string",
        "enum": [
          "pending",
          "approved",
          "rejected",
          "cancelled"
        ]
      },
      "ApprovalActionType": {
        "type": "string",
        "enum": [
          "approve",
          "reject"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "$ref": "#/components/schemas/UserRole"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/User"
          },
          "token": {
            "type": "string",
            "example": "1|UVSuJAp4PIhbV0tfdk4bSVUFMXqc9jOTMrndPtIO4e6ddd6c"
          }
        }
      },
      "FormFieldOption": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "value": {
            "type": "string",
            "example": "travel"
          },
          "label": {
            "type": "string",
            "example": "Travel"
          },
          "sort_order": {
            "type": "integer"
          }
        }
      },
      "FormField": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "key": {
            "type": "string",
            "example": "amount"
          },
          "label": {
            "type": "string",
            "example": "Amount (USD)"
          },
          "type": {
            "$ref": "#/components/schemas/FieldType"
          },
          "is_required": {
            "type": "boolean"
          },
          "sort_order": {
            "type": "integer"
          },
          "min_value": {
            "type": "integer",
            "nullable": true
          },
          "max_value": {
            "type": "integer",
            "nullable": true
          },
          "placeholder": {
            "type": "string",
            "nullable": true
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FormFieldOption"
            }
          }
        }
      },
      "FormFieldInput": {
        "type": "object",
        "required": [
          "key",
          "label",
          "type"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "example": "amount"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/FieldType"
          },
          "is_required": {
            "type": "boolean",
            "default": false
          },
          "sort_order": {
            "type": "integer"
          },
          "min_value": {
            "type": "integer",
            "nullable": true
          },
          "max_value": {
            "type": "integer",
            "nullable": true
          },
          "placeholder": {
            "type": "string",
            "nullable": true
          },
          "options": {
            "type": "array",
            "description": "Required when type=select.",
            "items": {
              "type": "object",
              "required": [
                "value",
                "label"
              ],
              "properties": {
                "value": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "sort_order": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "WorkflowStep": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "step_order": {
            "type": "integer"
          },
          "approver_id": {
            "type": "integer"
          },
          "approver": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              }
            }
          }
        }
      },
      "Workflow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "form_id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/WorkflowType"
          },
          "required_approvals": {
            "type": "integer"
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkflowStep"
            }
          }
        }
      },
      "Form": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "example": "Expense Reimbursement"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "is_active": {
            "type": "boolean"
          },
          "created_by": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FormField"
            }
          },
          "workflow": {
            "$ref": "#/components/schemas/Workflow"
          }
        }
      },
      "ApprovalRequestValue": {
        "type": "object",
        "properties": {
          "form_field_id": {
            "type": "integer"
          },
          "field_key": {
            "type": "string",
            "example": "amount"
          },
          "field_label": {
            "type": "string"
          },
          "field_type": {
            "$ref": "#/components/schemas/FieldType"
          },
          "value": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "ApprovalAction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "action": {
            "$ref": "#/components/schemas/ApprovalActionType"
          },
          "comment": {
            "type": "string",
            "nullable": true
          },
          "step_order": {
            "type": "integer",
            "nullable": true
          },
          "acted_at": {
            "type": "string",
            "format": "date-time"
          },
          "approver": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              }
            }
          }
        }
      },
      "ApprovalRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "$ref": "#/components/schemas/RequestStatus"
          },
          "current_step_order": {
            "type": "integer",
            "nullable": true,
            "description": "Only meaningful for sequential workflows."
          },
          "requester_id": {
            "type": "integer"
          },
          "requester": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              }
            }
          },
          "form": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "workflow": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "type": {
                "$ref": "#/components/schemas/WorkflowType"
              }
            }
          },
          "values": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApprovalRequestValue"
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApprovalAction"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "The given data was invalid."
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "responses": {
      "Unauthenticated": {
        "description": "Missing or invalid token.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Unauthenticated."
            }
          }
        }
      },
      "Forbidden": {
        "description": "Authenticated, but role/scope check failed.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Forbidden."
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Validation failed.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register a new user and receive a token.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "email",
                  "password",
                  "password_confirmation"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 8
                  },
                  "password_confirmation": {
                    "type": "string",
                    "format": "password"
                  },
                  "role": {
                    "$ref": "#/components/schemas/UserRole"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registered.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Exchange credentials for a Sanctum token.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "admin@cyberagora.test"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Revoke the current access token.",
        "responses": {
          "200": {
            "description": "Logged out.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Logged out."
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Current authenticated user.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/forms": {
      "get": {
        "tags": [
          "Forms (public)"
        ],
        "summary": "List active forms (cached).",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Form"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/forms/{id}": {
      "get": {
        "tags": [
          "Forms (public)"
        ],
        "summary": "Show form schema (cached).",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Form"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/forms/{form}/requests": {
      "post": {
        "tags": [
          "Requester"
        ],
        "summary": "Submit a filled form.",
        "parameters": [
          {
            "in": "path",
            "name": "form",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "values"
                ],
                "properties": {
                  "values": {
                    "type": "object",
                    "description": "Map of field_key → value. Values are validated against the form's dynamic schema.",
                    "example": {
                      "title": "NYC trip",
                      "amount": 850,
                      "category": "travel",
                      "incurred_on": "2026-04-12",
                      "reimbursable": true,
                      "notes": "3 nights"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/ApprovalRequest"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        }
      }
    },
    "/my/requests": {
      "get": {
        "tags": [
          "Requester"
        ],
        "summary": "List the current user's submitted requests.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ApprovalRequest"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/my/requests/{approvalRequest}": {
      "get": {
        "tags": [
          "Requester"
        ],
        "summary": "Show one of the current user's requests with its full action trail.",
        "parameters": [
          {
            "in": "path",
            "name": "approvalRequest",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/ApprovalRequest"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Not the requester of this request.",
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/approvals/pending": {
      "get": {
        "tags": [
          "Approver"
        ],
        "summary": "Requests waiting on the current approver to act.",
        "description": "For sequential workflows, this returns requests whose `current_step_order` matches a step assigned to the current user.\nFor threshold workflows, this returns pending requests where the user is in the approver pool and has not already acted.\n",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ApprovalRequest"
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/approvals/past": {
      "get": {
        "tags": [
          "Approver"
        ],
        "summary": "Requests this approver has already acted on.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ApprovalRequest"
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/approvals/{approvalRequest}": {
      "get": {
        "tags": [
          "Approver"
        ],
        "summary": "Show a request the approver may act on or has acted on.",
        "parameters": [
          {
            "in": "path",
            "name": "approvalRequest",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/ApprovalRequest"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Approver is neither in the workflow nor has acted on this request.",
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/approvals/{approvalRequest}/approve": {
      "post": {
        "tags": [
          "Approver"
        ],
        "summary": "Approve a request.",
        "description": "- **Sequential**: advances `current_step_order`; once past the last step, status becomes `approved`.\n- **Threshold**: counts approvals; once `required_approvals` is reached, status becomes `approved`.\n",
        "parameters": [
          {
            "in": "path",
            "name": "approvalRequest",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "comment": {
                    "type": "string",
                    "nullable": true,
                    "maxLength": 2000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action recorded.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/ApprovalRequest"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Not authorised to act now (not your turn / already acted / completed).",
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        }
      }
    },
    "/approvals/{approvalRequest}/reject": {
      "post": {
        "tags": [
          "Approver"
        ],
        "summary": "Reject a request — flips status to `rejected` immediately.",
        "parameters": [
          {
            "in": "path",
            "name": "approvalRequest",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "comment": {
                    "type": "string",
                    "nullable": true,
                    "maxLength": 2000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rejected.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/ApprovalRequest"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        }
      }
    },
    "/admin/forms": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "List all forms (active and inactive).",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Form"
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Create a form with its dynamic field schema.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "fields"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string",
                    "nullable": true
                  },
                  "is_active": {
                    "type": "boolean",
                    "default": true
                  },
                  "fields": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "$ref": "#/components/schemas/FormFieldInput"
                    }
                  }
                }
              },
              "examples": {
                "expense": {
                  "value": {
                    "name": "Expense Reimbursement",
                    "description": "Submit a business expense.",
                    "is_active": true,
                    "fields": [
                      {
                        "key": "title",
                        "label": "Title",
                        "type": "text",
                        "is_required": true
                      },
                      {
                        "key": "amount",
                        "label": "Amount",
                        "type": "number",
                        "is_required": true,
                        "min_value": 1,
                        "max_value": 10000
                      },
                      {
                        "key": "category",
                        "label": "Category",
                        "type": "select",
                        "is_required": true,
                        "options": [
                          {
                            "value": "travel",
                            "label": "Travel"
                          },
                          {
                            "value": "meals",
                            "label": "Meals"
                          }
                        ]
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Form"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        }
      }
    },
    "/admin/forms/{form}": {
      "put": {
        "tags": [
          "Admin"
        ],
        "summary": "Replace a form's metadata + field schema.",
        "parameters": [
          {
            "in": "path",
            "name": "form",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "fields"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string",
                    "nullable": true
                  },
                  "is_active": {
                    "type": "boolean"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/FormFieldInput"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Form"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        }
      },
      "delete": {
        "tags": [
          "Admin"
        ],
        "summary": "Delete a form (cascades to fields, workflow, requests, values, actions).",
        "parameters": [
          {
            "in": "path",
            "name": "form",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Deleted."
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/admin/forms/{form}/workflow": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Show the form's workflow (if any).",
        "parameters": [
          {
            "in": "path",
            "name": "form",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Workflow"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Configure (create or replace) the form's workflow.",
        "parameters": [
          {
            "in": "path",
            "name": "form",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "type",
                  "steps"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "$ref": "#/components/schemas/WorkflowType"
                  },
                  "required_approvals": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Used by threshold workflows. Defaults to step count."
                  },
                  "steps": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": [
                        "approver_id"
                      ],
                      "properties": {
                        "approver_id": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              },
              "examples": {
                "sequential": {
                  "summary": "2-step sequential",
                  "value": {
                    "name": "Two-step manager approval",
                    "type": "sequential",
                    "steps": [
                      {
                        "approver_id": 4
                      },
                      {
                        "approver_id": 5
                      }
                    ]
                  }
                },
                "threshold": {
                  "summary": "2-of-3 threshold",
                  "value": {
                    "name": "Two-of-three leads",
                    "type": "threshold",
                    "required_approvals": 2,
                    "steps": [
                      {
                        "approver_id": 4
                      },
                      {
                        "approver_id": 5
                      },
                      {
                        "approver_id": 6
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Configured.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Workflow"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          }
        }
      }
    },
